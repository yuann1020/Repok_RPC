# Local ports:
# - http://localhost:3000 is the frontend website.
# - http://localhost:3001 is the backend API.
# FRONTEND_URL must be localhost:3000 locally because Stripe success/cancel pages are frontend pages.
# Stripe webhook must forward to localhost:3001 because the webhook controller is in the NestJS backend.
# STRIPE_WEBHOOK_SECRET comes from the Stripe CLI listen command.

PORT=3001
DATABASE_URL=
JWT_SECRET=
GOOGLE_CLIENT_ID=
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000
BOOKING_HOLD_MINUTES=10
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
